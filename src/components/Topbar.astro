---
const { user } = Astro.locals;
---

<header class="border-border bg-background border-b">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
    <a href="/recipes" class="text-foreground hover:text-muted-foreground text-sm font-semibold transition-colors">
      Snapchef
    </a>
    <div class="flex items-center gap-4">
      <span class="text-muted-foreground hidden text-sm sm:block">{user?.email}</span>
      <form method="POST" action="/api/auth/signout">
        <button type="submit" class="text-muted-foreground hover:text-foreground text-sm transition-colors">
          Sign out
        </button>
      </form>
    </div>
  </div>
</header>
