---
import type { RecognizedItem } from "@/lib/core/model/recipe";

interface Props {
  mealContext: string | null;
  items: RecognizedItem[];
  photos: { id: string; photoUrl: string }[];
}

const { mealContext, items, photos } = Astro.props;
---

<section class="flex flex-col gap-8">
  {
    mealContext && (
      <div class="flex flex-col gap-2">
        <h2 class="text-foreground text-lg font-semibold">Kontekst posiłku</h2>
        <p class="text-muted-foreground text-sm whitespace-pre-line">{mealContext}</p>
      </div>
    )
  }

  {
    items.length > 0 && (
      <div class="flex flex-col gap-2">
        <h2 class="text-foreground text-lg font-semibold">Lista produktów</h2>
        <ul class="text-muted-foreground flex flex-col gap-1 text-sm">
          {items.map((item) => (
            <li>
              <span class="text-foreground font-medium">{item.name}</span>
              {item.quantity && <span> — {item.quantity}</span>}
            </li>
          ))}
        </ul>
      </div>
    )
  }

  {
    photos.length > 0 && (
      <div class="flex flex-col gap-2">
        <h2 class="text-foreground text-lg font-semibold">Zdjęcia</h2>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
          {photos.map((photo) => (
            <img
              src={photo.photoUrl}
              alt="Zdjęcie produktów"
              loading="lazy"
              class="ring-foreground/10 aspect-square w-full rounded-none object-cover ring-1"
            />
          ))}
        </div>
      </div>
    )
  }
</section>
