---
import PublicLayout from "@/layouts/PublicLayout.astro";
import { Button } from "@/components/ui/button";
import { Card, CardHeader, CardTitle, CardDescription } from "@/components/ui/card";
import { Camera, ListChecks, ChefHat } from "lucide-react";
---

<PublicLayout title="Snapchef">
  <div class="mx-auto flex max-w-5xl flex-col items-center px-4 py-16 sm:py-24">
    <!-- Hero -->
    <div class="mb-16 text-center">
      <h1 class="text-foreground mb-4 text-4xl font-semibold sm:text-5xl">Snapchef</h1>
      <p class="text-muted-foreground mb-8 max-w-xl text-base sm:text-lg">
        Snap a photo of your fridge, get a recipe. No planning, no waste.
      </p>
      <div class="flex flex-col gap-3 sm:flex-row sm:justify-center">
        <Button asChild size="lg">
          <a href="/auth/signup">Get started</a>
        </Button>
        <Button asChild variant="outline" size="lg">
          <a href="/auth/signin">Sign in</a>
        </Button>
      </div>
    </div>

    <!-- Value props -->
    <div class="grid w-full grid-cols-1 gap-4 sm:grid-cols-3">
      <Card>
        <CardHeader>
          <Camera className="text-muted-foreground mb-2 size-5" client:load />
          <CardTitle>Snap your fridge</CardTitle>
          <CardDescription>Upload 1–5 photos and let the AI recognise your ingredients automatically.</CardDescription>
        </CardHeader>
      </Card>
      <Card>
        <CardHeader>
          <ListChecks className="text-muted-foreground mb-2 size-5" client:load />
          <CardTitle>Review the list</CardTitle>
          <CardDescription>Edit names and quantities, add anything missing, remove what you don't want.</CardDescription
          >
        </CardHeader>
      </Card>
      <Card>
        <CardHeader>
          <ChefHat className="text-muted-foreground mb-2 size-5" client:load />
          <CardTitle>Get a recipe</CardTitle>
          <CardDescription>Describe the meal context and receive a full recipe — saved to your account.</CardDescription
          >
        </CardHeader>
      </Card>
    </div>
  </div>
</PublicLayout>
