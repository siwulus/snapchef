---
import AppLayout from "@/layouts/AppLayout.astro";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { buttonVariants } from "@/components/ui/button";

const user = Astro.locals.user;
---

<AppLayout title="Recipes — Snapchef">
  <div class="flex flex-col gap-6">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <h1 class="text-foreground text-2xl font-semibold">
          {user?.email ? `Welcome, ${user.email}` : "Your Recipes"}
        </h1>
        <p class="text-muted-foreground mt-1 text-sm">Your recipe collection will appear here.</p>
      </div>
      <a href="/recipes/new" class:list={[buttonVariants()]}>Nowy przepis</a>
    </div>
    <Card>
      <CardHeader>
        <CardTitle>No recipes yet</CardTitle>
      </CardHeader>
      <CardContent class="flex flex-col items-start gap-4">
        <p class="text-muted-foreground text-sm">Start building your collection by adding your first recipe.</p>
        <a href="/recipes/new" class:list={[buttonVariants()]}>Dodaj pierwszy przepis</a>
      </CardContent>
    </Card>
  </div>
</AppLayout>
