---
import { BackToRecipies } from "@/components/navigation/BackToRecipies";
import { ProductListView } from "@/components/recipes/ingridients/ProductListView";
import { PhotoGrid } from "@/components/recipes/photo/PhotoGrid";
import DeleteRecipeButton from "@/components/recipes/recipe/DeleteRecipeButton";
import { RecipeContextView } from "@/components/recipes/recipe/RecipeContextView";
import { RecipeView } from "@/components/recipes/recipe/RecipeView";
import AppLayout from "@/layouts/AppLayout.astro";
import { RecipeSessionId } from "@/lib/core/model/recipe";
import { runWithLogging } from "@/lib/infrastructure/logging/logger";
import { Effect } from "effect";

export const prerender = false;

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect("/auth/signin");
}

const idResult = RecipeSessionId.safeParse(Astro.params.id);
if (!idResult.success) {
  return Astro.redirect("/recipes");
}

// Reuse the sanctioned page edge (see confirm.astro): collapse both channels with Effect.match to
// detail-or-null. A missing/foreign/non-saved session surfaces as NotFound → null → redirect, so
// the single guard below covers every "not viewable" case uniformly.
const detail = await runWithLogging(
  Astro.locals.recipeSessions.getSavedRecipe(user.id, idResult.data).pipe(
    Effect.match({
      onFailure: () => null,
      onSuccess: (value) => value,
    }),
  ),
);

if (!detail) {
  return Astro.redirect("/recipes");
}
---

<AppLayout title={`${detail.recipe.name} — Snapchef`}>
  <div class="flex flex-col gap-8">
    <div>
      <BackToRecipies href="/recipes" />
    </div>

    <RecipeView name={detail.recipe.name} contentMd={detail.recipe.contentMd} />
    <RecipeContextView mealContext={detail.mealContext ?? ""} />
    <ProductListView items={detail.items ?? []} />
    <PhotoGrid photos={detail.photos ?? []} />

    <div class="flex justify-between border-t pt-6">
      <BackToRecipies href="/recipes" />
      <DeleteRecipeButton sessionId={detail.recipe.sessionId} client:visible />
    </div>
  </div>
</AppLayout>
