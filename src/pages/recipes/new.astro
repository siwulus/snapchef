---
import AppLayout from "@/layouts/AppLayout.astro";
import RecipeWizard from "@/components/recipes/wizard/RecipeWizard";
---

<AppLayout title="Nowy przepis — Snapchef">
  <div class="flex flex-col gap-6">
    <div>
      <h1 class="text-foreground text-2xl font-semibold">Nowy przepis</h1>
      <p class="text-muted-foreground mt-1 text-sm">Prześlij od 1 do 5 zdjęć produktów, aby rozpocząć.</p>
    </div>
    <RecipeWizard client:load />
  </div>
</AppLayout>
