---
import ResendConfirmation from "@/components/auth/ResendConfirmation";
import PublicLayout from "@/layouts/PublicLayout.astro";
---

<PublicLayout title="Check your email">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="border-border bg-card w-full max-w-sm border p-8 text-center">
      <div class="mb-4 text-5xl">📧</div>
      <h1 class="text-foreground mb-3 text-2xl font-semibold">Check your email</h1>
      <p class="text-muted-foreground mb-6">
        We've sent a confirmation link to your email address. Click it to activate your account. Didn't get it? Enter
        your email below to resend.
      </p>
      <ResendConfirmation client:load />
      <a
        href="/auth/signin"
        class="text-muted-foreground hover:text-foreground mt-4 inline-block text-sm underline underline-offset-4"
      >
        Back to sign in
      </a>
    </div>
  </div>
</PublicLayout>
