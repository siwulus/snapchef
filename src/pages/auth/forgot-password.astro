---
import ForgotPasswordForm from "@/components/auth/ForgotPasswordForm";
import PublicLayout from "@/layouts/PublicLayout.astro";
---

<PublicLayout title="Reset your password">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="border-border bg-card w-full max-w-sm border p-8 text-center">
      <h1 class="text-foreground mb-3 text-2xl font-semibold">Reset your password</h1>
      <p class="text-muted-foreground mb-6">
        Enter the email address for your account and we'll send you a link to set a new password.
      </p>
      <ForgotPasswordForm client:load />
      <a
        href="/auth/signin"
        class="text-muted-foreground hover:text-foreground mt-4 inline-block text-sm underline underline-offset-4"
      >
        Back to sign in
      </a>
    </div>
  </div>
</PublicLayout>
