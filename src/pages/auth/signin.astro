---
import PublicLayout from "@/layouts/PublicLayout.astro";
import SignInForm from "@/components/auth/SignInForm";
---

<PublicLayout title="Sign in">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="border-border bg-card w-full max-w-sm border p-8">
      <h1 class="text-foreground mb-6 text-center text-2xl font-semibold">Sign in</h1>
      <SignInForm client:load />
      <p class="text-muted-foreground mt-4 text-center text-sm">
        Don't have an account?{" "}
        <a href="/auth/signup" class="text-foreground hover:text-muted-foreground underline underline-offset-4"
          >Sign up</a
        >
      </p>
    </div>
  </div>
</PublicLayout>
