---
import PublicLayout from "@/layouts/PublicLayout.astro";
import { EmailConfirmation } from "@/lib/core/boundry/auth";
import { runWithLogging } from "@/lib/infrastructure/logging/logger";
import { decodeWith } from "@/lib/utils/effect";
import { Effect } from "effect";

export const prerender = false;

// Redeem the emailed token_hash. confirmEmail runs verifyOtp through the request-scoped Supabase
// client wired in middleware (Astro.locals.authenticator), so a successful verify writes the
// session cookie onto this response and the redirect below lands authenticated. Both channels are
// collapsed with Effect.match into a boolean, run through the shared logger runtime (runWithLogging)
// — the same edge used by runApiRoute and middleware — so this sanctioned page edge logs uniformly.
const confirmed = await runWithLogging(
  decodeWith(EmailConfirmation)({
    tokenHash: Astro.url.searchParams.get("token_hash") ?? "",
    type: Astro.url.searchParams.get("type") ?? "",
  }).pipe(
    Effect.flatMap((confirmation) => Astro.locals.authenticator.confirmEmail(confirmation)),
    // Surface the failing cause through the shared logger (same as runApiRoute / middleware) before
    // collapsing both channels — the error card itself is intentionally generic for the user.
    Effect.tapError((cause) => Effect.logError("auth.confirm.failed", cause)),
    Effect.match({
      onFailure: () => false,
      onSuccess: () => true,
    }),
  ),
);

if (confirmed) {
  return Astro.redirect("/recipes");
}
---

<PublicLayout title="Confirmation failed">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="border-border bg-card w-full max-w-sm border p-8 text-center">
      <div class="mb-4 text-5xl">⚠️</div>
      <h1 class="text-foreground mb-3 text-2xl font-semibold">This link is invalid or has expired</h1>
      <p class="text-muted-foreground mb-6">
        We couldn't confirm your email with this link. It may have already been used or have expired. Request a fresh
        confirmation email and try again.
      </p>
      <div class="flex flex-col gap-3">
        <a
          href="/auth/confirm-email"
          class="text-foreground hover:text-muted-foreground text-sm underline underline-offset-4"
        >
          Resend confirmation email
        </a>
        <a href="/auth/signin" class="text-muted-foreground hover:text-foreground text-sm underline underline-offset-4">
          Back to sign in
        </a>
      </div>
    </div>
  </div>
</PublicLayout>
