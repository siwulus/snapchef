---
import ResetPasswordForm from "@/components/auth/ResetPasswordForm";
import PublicLayout from "@/layouts/PublicLayout.astro";

export const prerender = false;

// Read the recovery token from the emailed link and hand it to the form island. Do NOT call verifyOtp
// here — the recovery token is single-use and redemption happens once, on the form's POST (see the
// plan's Critical Implementation Details). A missing token renders the generic invalid-link card.
const tokenHash = Astro.url.searchParams.get("token_hash");
---

<PublicLayout title={tokenHash ? "Set a new password" : "This link is invalid or has expired"}>
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="border-border bg-card w-full max-w-sm border p-8">
      {
        tokenHash ? (
          <Fragment>
            <h1 class="text-foreground mb-2 text-center text-2xl font-semibold">Set a new password</h1>
            <p class="text-muted-foreground mb-6 text-center text-sm">Choose a new password for your account.</p>
            <ResetPasswordForm client:load tokenHash={tokenHash} />
          </Fragment>
        ) : (
          <div class="text-center">
            <div class="mb-4 text-5xl">⚠️</div>
            <h1 class="text-foreground mb-3 text-2xl font-semibold">This link is invalid or has expired</h1>
            <p class="text-muted-foreground mb-6">
              We couldn't open the password reset form with this link. It may have already been used or have expired.
              Request a fresh reset link and try again.
            </p>
            <div class="flex flex-col gap-3">
              <a
                href="/auth/forgot-password"
                class="text-foreground hover:text-muted-foreground text-sm underline underline-offset-4"
              >
                Request a new reset link
              </a>
              <a
                href="/auth/signin"
                class="text-muted-foreground hover:text-foreground text-sm underline underline-offset-4"
              >
                Back to sign in
              </a>
            </div>
          </div>
        )
      }
    </div>
  </div>
</PublicLayout>
