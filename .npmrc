# pnpm is pinned via mise (see mise.toml: "npm:pnpm" = "11.6.0") and the
# packageManager field in package.json. A standalone/corepack pnpm that is NOT
# mise's (e.g. the one a GUI editor like Cursor puts on PATH for commit hooks)
# tries to self-switch to the pinned version and can fail on a binary-layout
# mismatch ("Failed to switch pnpm to v11.6.0 ... bin/pnpm ENOENT").
# mise already guarantees the pinned version, so disable pnpm's self-switching.
manage-package-manager-versions=false
